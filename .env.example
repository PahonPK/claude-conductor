# .env.example — machine-specific values reference
#
# These are the per-machine / secret values your live `~/.claude` setup may need.
# They are GITIGNORED and never committed. Listed here only so a new machine
# knows what to supply locally.
#
# Copy this file to `.env`, fill in real values, and keep `.env` out of git
# (it is already in .gitignore). Actual Claude credentials live in
# `~/.claude/.credentials.json` — that file is gitignored and never copied here.

# --- Infrastructure (fill with your own) ---
VPS_IP=                 # your server / VPS IP
APP_BASE_URL=           # primary app base URL, e.g. https://app.example.com

# --- Automation platform (optional) ---
AUTOMATION_BASE_URL=    # workflow-automation base URL (e.g. n8n / Make)
AUTOMATION_API_KEY=     # automation API key (NEVER commit)

# --- Database / backend (optional) ---
DB_URL=                 # database / backend URL
DB_SERVICE_KEY=         # service-role key (NEVER commit)

# --- Notes ---
# Claude API credentials, OAuth tokens, and MCP auth caches are managed by the
# Claude CLI itself inside ~/.claude (.credentials.json, mcp-needs-auth-cache.json).
# Those files are runtime/secret and are intentionally NOT part of this repo.
